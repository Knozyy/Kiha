# === KIHA Environment Variables ===

# --- Server ---
KIHA_SERVER_HOST=0.0.0.0
KIHA_SERVER_PORT=8000
KIHA_DEBUG=false

# --- Database (PostgreSQL) ---
KIHA_DB_HOST=localhost
KIHA_DB_PORT=5432
KIHA_DB_NAME=kiha
KIHA_DB_USER=kiha_user
KIHA_DB_PASSWORD=CHANGE_ME

# --- Cache (Redis) ---
KIHA_REDIS_HOST=localhost
KIHA_REDIS_PORT=6379
KIHA_REDIS_PASSWORD=CHANGE_ME

# --- Authentication (JWT) ---
KIHA_JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET
KIHA_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
KIHA_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Security ---
KIHA_API_SECRET=CHANGE_ME
KIHA_DTLS_PSK=CHANGE_ME

# --- AI Inference ---
KIHA_MODEL_PATH=./models/yolov8n.onnx
KIHA_INFERENCE_DEVICE=cuda

# --- UDP Receiver ---
KIHA_UDP_HOST=0.0.0.0
KIHA_UDP_PORT=9000

# --- WebSocket ---
KIHA_WS_PORT=8001
